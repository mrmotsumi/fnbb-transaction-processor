# =============================================================================
# FNBB Transaction Processor — Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================================

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production

# ── Database (MySQL / MariaDB) ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=transaction_db

# ── Application Secrets ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace_with_32_char_random_string
JWT_SECRET_KEY=replace_with_different_32_char_random_string

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL_DAILY_SUMMARY=300
CACHE_TTL_TRANSACTIONS=60
CACHE_TTL_REPORTS=3600
CACHE_TTL_USERS=120

# ── JWT ───────────────────────────────────────────────────────────────────────
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Downstream PHP Lending System ─────────────────────────────────────────────
PHP_API_BASE_URL=https://your-lending-system.example.com/api
PHP_API_KEY=your_php_api_key
PHP_API_TIMEOUT=30
PHP_API_MAX_RETRIES=3
PHP_API_RETRY_DELAY=5
PHP_BATCH_SIZE=50

# ── Initial Admin User ────────────────────────────────────────────────────────
# Used once on first startup when no users exist
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_DEFAULT_PASSWORD=ChangeMe@1234   # Change immediately after first login

# ── Report Display Info ───────────────────────────────────────────────────────
# These appear in generated PDF/Excel report headers only
REPORT_ACCOUNT_NAME=Your Company Name
REPORT_ACCOUNT_NUMBER=XXXXXXXXXXXX

# ── Production Only ───────────────────────────────────────────────────────────
# ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
